# =============================================================================
# 菲特数据生成平台 — 单一事实源配置（端口与交互地址）
# =============================================================================
# 修改此文件后，需重启相关服务。脚本与文档均引用此处配置。
#
# 用法：
#   source platform.config.env   # 在脚本中加载
#   或由 docs/.env.platform 间接加载
# =============================================================================

# ----- 服务端口 -----
FRONTEND_PORT="3006"
BACKEND_PORT="9999"
POSTGRES_PORT="5432"
COMFYUI_PORT_RANGE="8200-8299"
ANNOTATION_PORT_RANGE="7860-7899"

# ----- 监听地址（127.0.0.1=仅本机，0.0.0.0=允许局域网）-----
FRONTEND_HOST="0.0.0.0"
BACKEND_HOST="0.0.0.0"

# ----- 由端口派生的 URL（根据 BACKEND_PORT 自动推导）-----
PLATFORM_INTERNAL_HOST="127.0.0.1"
VITE_API_PROXY_URL="http://127.0.0.1:${BACKEND_PORT}"
PLATFORM_CALLBACK_URL="http://127.0.0.1:${BACKEND_PORT}/api/internal/comfy/callback"
