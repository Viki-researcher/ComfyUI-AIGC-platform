# 【开发】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 请求基础路径（开发环境设置为 / 使用代理，生产环境设置为完整后端地址）
VITE_API_URL = /

# 代理目标地址（应与 docs/.env.platform 中 BACKEND_PORT 一致；使用 start_all.sh 时会自动注入；手动 pnpm dev 前可运行 docs/scripts/sync_ports_to_frontend.sh 同步）
VITE_API_PROXY_URL = http://127.0.0.1:8989

# Delete console
VITE_DROP_CONSOLE = false

# 应用版本号
VITE_VERSION = 0.4.0

# 开发联调：关闭登录拖拽验证
VITE_DISABLE_DRAG_VERIFY = true