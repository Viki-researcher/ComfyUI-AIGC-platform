# 平台一键启动脚本环境变量示例
# 用法：
#   cp .env.platform.example .env.platform
#   然后按需修改路径、数据库连接
#
# 注意：端口配置在项目根目录 platform.config.env（单一事实源），
# 脚本会先加载该文件。此处可覆盖端口，但建议统一在 platform.config.env 修改。

# ===== 代码路径（使用项目根目录，脚本中 PROJECT_ROOT 已定义）=====
# 若项目在 /workspace，则以下路径自动解析；移动项目后只需改 PROJECT_ROOT 的推导逻辑
ART_FRONTEND_DIR="${PROJECT_ROOT}/art-design-pro"
BACKEND_DIR="${PROJECT_ROOT}/vue-fastapi-admin-main"
COMFYUI_REPO_PATH="${PROJECT_ROOT}/ComfyUI-master-fitow"

# ===== 服务监听（可选覆盖 platform.config.env）=====
# 默认已从 platform.config.env 加载；此处可覆盖
# FRONTEND_HOST="0.0.0.0"
# FRONTEND_PORT="3006"
# BACKEND_HOST="0.0.0.0"
# BACKEND_PORT="9999"

# ===== Python 可执行文件 =====
# 方式一：conda 环境
# BACKEND_PY="${CONDA_PREFIX}/../datagen-backend/bin/python"
# COMFYUI_PYTHON="${CONDA_PREFIX}/../datagen-comfyui/bin/python"
# 方式二：系统 python / venv（开发机常用）
BACKEND_PY="/usr/bin/python3"
COMFYUI_PYTHON="/usr/bin/python3"

# ===== 后端数据库（PostgreSQL）=====
DB_DEFAULT_CONNECTION="postgres"
POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT="${POSTGRES_PORT:-5432}"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="data_generation"

# ===== ComfyUI 实例管理 =====
COMFYUI_LISTEN="0.0.0.0"
COMFYUI_INTERNAL_HOST=""
COMFYUI_PUBLIC_BASE_URL=""
COMFYUI_PORT_RANGE="${COMFYUI_PORT_RANGE:-8200-8299}"
COMFYUI_INSTANCE_BASE_DIR="runtime/comfy_instances"
COMFYUI_LOG_DIR="runtime/comfy_logs"
COMFYUI_STARTUP_TIMEOUT_SECONDS="240"
COMFYUI_HEARTBEAT_INTERVAL_SECONDS="30"
COMFYUI_HISTORY_SYNC_INTERVAL_SECONDS="10"
COMFYUI_FORCE_CPU="true"

# ===== ComfyUI -> 平台回调（可选）=====
PLATFORM_INTERNAL_SECRET="platform_secret_key_2026"
# PLATFORM_CALLBACK_URL 已由 platform.config.env 根据 BACKEND_PORT 生成

# ===== 前端 env（VITE_API_PROXY_URL 已由 platform.config.env 生成）=====
VITE_DISABLE_DRAG_VERIFY="true"
